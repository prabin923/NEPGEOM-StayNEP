# Copy to .env and fill in values (do not commit .env)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
NEXTAUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
AUTH_SECRET="same-as-nextauth-secret-for-nextauth-v5"
# Stable Server Action IDs across deploys (required on Vercel). Generate: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="your-base64-32-byte-key"
# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID="your-google-oauth-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"
GEMINI_API_KEY="your-google-ai-studio-key"
GEMINI_MODEL="gemini-2.0-flash"
NEXT_PUBLIC_GEOAPIFY_API_KEY="your-geoapify-api-key"
# Optional server-only override for Places, reverse geocoding, and routing.
GEOAPIFY_API_KEY="your-geoapify-api-key"
